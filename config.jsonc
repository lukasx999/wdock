{
  "general": {
    "width": 500,
    "height": 500,
    "anchor": "right",
    "margin": {
      "top": 0,
      "right": 0,
      "bottom": 0,
      "left": 0,
    },
  },
  "modules": ["date", "time", "uname"],
  "configuration": {
    "date": {
      "timezone": "Europe/Vienna",
      "format": "{:%d.%m.%Y}",
    },
    "time": {
      "timezone": "Europe/Vienna",
      "format": "{:%H:%M}",
    },
    "uname": {
      "format": "{sysname} {nodename} {release} {machine}",
    },
  },
}
